# Copy this file to .env and fill in your values.

# Timezone — find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# Web UI port
WEB_PORT=8080

# Your location — used for species range filtering
BIRDNET_LATITUDE=
BIRDNET_LONGITUDE=

# USB microphone avfoundation device indices.
# Run ./find-mic.sh to discover available devices, then set the numbers here.
# Example: if find-mic.sh shows "[1] USB Audio Device", set MIC_DEVICE=1
# Use the exact device name from ./find-mic.sh (more stable than index numbers).
# Quote names that contain spaces or parentheses.
# Example: MIC_DEVICE="Hermes (17) Microphone"
MIC_DEVICE=
MIC_DEVICE_2=   # optional; leave blank to disable
MIC_DEVICE_3=   # optional; leave blank to disable
MIC_DEVICE_4=   # optional; leave blank to disable
MIC_DEVICE_5=   # optional; leave blank to disable

# Container file ownership — match your macOS user.
# Find yours with: id -u  and  id -g
BIRDNET_UID=501
BIRDNET_GID=20
