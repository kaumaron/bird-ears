# Copy this file to .env and fill in your values.

# Timezone — find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# Web UI port
WEB_PORT=8080

# USB microphone avfoundation device index.
# Run ./find-mic.sh to discover available devices, then set the number here.
# Example: if find-mic.sh shows "[1] USB Audio Device", set MIC_DEVICE=1
MIC_DEVICE=

# Container file ownership — match your macOS user.
# Find yours with: id -u  and  id -g
BIRDNET_UID=501
BIRDNET_GID=20
